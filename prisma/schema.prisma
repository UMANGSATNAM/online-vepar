// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  avatar    String?
  role      String   @default("owner") // owner, staff
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  stores    Store[]
  orders    Order[]
}

model Store {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  logo        String?
  banner      String?
  theme       String   @default("modern") // modern, classic, minimal, bold
  primaryColor String  @default("#10b981") // emerald green for Online Vepar
  currency    String   @default("INR")
  domain      String?
  isActive    Boolean  @default(true)
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  products    Product[]
  orders      Order[]
  customers   Customer[]
  categories  Category[]
  pages       Page[]
  discounts      Discount[]
  inventoryLogs  InventoryLog[]
  shippingZones  ShippingZone[]
  shipments      Shipment[]
  reviews        Review[]
  variants       ProductVariant[]
  activityLogs   ActivityLog[]
  taxRates       TaxRate[]
  abandonedCarts         AbandonedCart[]
  collections           Collection[]
  notificationPreference NotificationPreference?
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String
  image     String?
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  products  Product[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String
  description String?
  price       Float
  comparePrice Float?
  cost        Float?
  images      String   @default("[]") // JSON array of image URLs
  category    String?
  tags        String   @default("[]") // JSON array of tags
  sku         String?
  barcode     String?
  stock       Int      @default(0)
  trackInventory Boolean @default(true)
  weight      Float?
  weightUnit  String   @default("kg")
  status      String   @default("draft") // draft, active, archived
  featured    Boolean  @default(false)
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categoryId  String?
  categoryRef Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderItems     OrderItem[]
  inventoryLogs  InventoryLog[]
  reviews        Review[]
  variants       ProductVariant[]
  collectionProducts CollectionProduct[]
}

model Order {
  id            String   @id @default(cuid())
  orderNumber   String
  status        String   @default("pending") // pending, confirmed, processing, shipped, delivered, cancelled, refunded
  paymentStatus String   @default("unpaid") // unpaid, paid, partially_refunded, refunded
  fulfillmentStatus String @default("unfulfilled") // unfulfilled, partial, fulfilled
  subtotal      Float
  tax           Float    @default(0)
  shipping      Float    @default(0)
  discount      Float    @default(0)
  total         Float
  currency      String   @default("INR")
  customerName  String
  customerEmail String?
  customerPhone String?
  shippingAddress String?
  billingAddress  String?
  notes         String?
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  items         OrderItem[]
  shipments     Shipment[]
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  name      String
  price     Float
  quantity  Int
  total     Float
  createdAt DateTime @default(now())
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  zip       String?
  notes     String?
  totalOrders Int    @default(0)
  totalSpent  Float  @default(0)
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id        String   @id @default(cuid())
  title     String
  slug      String
  content   String?
  type      String   @default("page") // page, blog
  published Boolean  @default(false)
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Discount {
  id          String   @id @default(cuid())
  code        String   // e.g. "SUMMER2025"
  name        String   // Display name e.g. "Summer Sale 20% Off"
  description String?
  type        String   // "percentage" or "fixed_amount"
  value       Float    // e.g. 20 for 20% or 500 for ₹500 off
  minOrderAmount Float? // Minimum order value to apply
  maxDiscount Float?   // Maximum discount cap for percentage type
  usageLimit  Int?     // Total number of times this can be used
  usedCount   Int      @default(0)
  perCustomerLimit Int? // Max uses per customer
  appliesTo   String   @default("all") // "all", "specific_categories", "specific_products"
  applicableIds String @default("[]") // JSON array of category/product IDs
  startsAt    DateTime?
  endsAt      DateTime?
  isActive    Boolean  @default(true)
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InventoryLog {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  type          String   // "in", "out", "adjustment", "return"
  quantity      Int      // positive for in, negative for out
  previousStock Int
  newStock      Int
  reason        String?
  reference     String?  // order number, PO number, etc.
  createdAt     DateTime @default(now())

  @@index([productId])
  @@index([storeId])
}

model ProductVariant {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name         String   // e.g., "Red / Large", "Size M"
  sku          String?
  price        Float?   // null = same as parent product price
  comparePrice Float?
  stock        Int      @default(0)
  options      String   @default("{}") // JSON: { "Color": "Red", "Size": "Large" }
  position     Int      @default(0) // sort order
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([productId])
  @@index([storeId])
}

model ShippingZone {
  id          String   @id @default(cuid())
  name        String   // e.g., "Domestic - North India", "International - US"
  regions     String   // JSON array of regions/states/countries
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  rates       ShippingRate[]

  @@index([storeId])
}

model ShippingRate {
  id            String       @id @default(cuid())
  name          String       // e.g., "Standard", "Express", "Overnight"
  zoneId        String
  zone          ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  priceType     String       // "flat", "weight_based", "price_based"
  minWeight     Float?
  maxWeight     Float?
  minOrderValue Float?
  maxOrderValue Float?
  rate          Float        // shipping cost
  freeAbove     Float?       // free shipping above this order value
  estimatedDays String       // e.g., "3-5", "1-2"
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([zoneId])
}

model Review {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customerName  String
  customerEmail String?
  rating        Int      // 1-5 stars
  title         String?
  content       String?
  isVerified    Boolean  @default(false) // verified purchase
  isApproved    Boolean  @default(false) // merchant approval
  response      String?  // merchant response
  respondedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId])
  @@index([storeId])
}

model Shipment {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  storeId         String
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  trackingNumber  String?
  carrier         String?  // e.g., "Delhivery", "BlueDart", "DTDC", "India Post"
  shippingMethod  String?  // e.g., "Standard", "Express"
  status          String   @default("label_created") // label_created, picked_up, in_transit, out_for_delivery, delivered, failed, returned
  shippedAt       DateTime?
  deliveredAt     DateTime?
  weight          Float?
  dimensions      String?  // JSON: {length, width, height}
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([orderId])
  @@index([storeId])
}

model ActivityLog {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId      String?
  userName    String?
  action      String   // e.g., "product.created", "order.status_updated", "discount.activated"
  entity      String   // e.g., "product", "order", "customer", "discount"
  entityId    String?  // ID of the affected entity
  entityName  String?  // Human-readable name of the entity
  details     String?  // JSON string with additional context
  createdAt   DateTime @default(now())

  @@index([storeId])
  @@index([entity])
  @@index([createdAt])
}

model TaxRate {
  id          String   @id @default(cuid())
  name        String   // e.g., "GST 18%", "VAT 5%"
  rate        Float    // percentage, e.g., 18.0
  country     String?  // ISO country code, e.g., "IN"
  state       String?  // state/province
  city        String?
  zipCode     String?
  isCompound  Boolean  @default(false) // compound tax (tax on tax)
  priority    Int      @default(0) // higher priority applied first
  isActive    Boolean  @default(true)
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([storeId])
  @@index([country])
}

model AbandonedCart {
  id              String   @id @default(cuid())
  storeId         String
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customerEmail   String
  customerName    String?
  customerPhone   String?
  items           String   @default("[]") // JSON array of {productId, name, price, quantity, image}
  subtotal        Float    @default(0)
  tax             Float    @default(0)
  shipping        Float    @default(0)
  total           Float    @default(0)
  currency        String   @default("INR")
  recoveryToken   String   @unique // unique token for recovery URL
  recoveryUrl     String?  // full recovery URL
  status          String   @default("abandoned") // abandoned, email_sent, recovered, expired
  emailSentAt     DateTime?
  emailOpenedAt   DateTime?
  recoveredAt     DateTime?
  abandonedAt     DateTime @default(now())
  expiresAt       DateTime? // cart expiry date
  reminderCount   Int      @default(0) // number of reminder emails sent
  lastReminderAt  DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([storeId])
  @@index([status])
  @@index([customerEmail])
  @@index([abandonedAt])
}

model Collection {
  id          String   @id @default(cuid())
  name        String
  slug        String
  description String?
  image       String?
  type        String   @default("manual") // "manual" or "auto"
  conditions  String   @default("{}") // JSON for auto-collection rules like tags/category/price range
  sortOrder   String   @default("best-selling") // best-selling, alpha, price-asc, price-desc, newest
  status      String   @default("active") // active, draft
  featured    Boolean  @default(false)
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  collectionProducts CollectionProduct[]

  @@index([storeId])
  @@index([slug])
}

model CollectionProduct {
  id           String   @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  productId    String
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  position     Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([collectionId])
  @@index([productId])
}

model NotificationPreference {
  id                        String   @id @default(cuid())
  storeId                   String   @unique
  store                     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  newOrderEmail             Boolean  @default(true)
  orderStatusEmail          Boolean  @default(true)
  paymentReceivedEmail      Boolean  @default(true)
  lowStockEmail             Boolean  @default(true)
  lowStockThreshold         Int      @default(5)
  reviewEmail               Boolean  @default(true)
  abandonedCartEmail        Boolean  @default(true)
  abandonedCartReminderDelay Int     @default(24)
  weeklyReportEmail         Boolean  @default(true)
  monthlyReportEmail        Boolean  @default(false)
  newsletterEmail           Boolean  @default(true)
  reportEmail               String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}
